{
  "mcpServers": {
    "llm-tldr": {
      "type": "stdio",
      "command": "~/agent-skills/scripts/tldr-mcp-contained-launch.py",
      "args": []
    },
    "serena": {
      "type": "stdio",
      "command": "~/.local/bin/serena",
      "args": [
        "start-mcp-server",
        "--enable-web-dashboard",
        "false",
        "--open-web-dashboard",
        "false"
      ]
    }
  }
}
