{
  "mcpServers": {
    "context-plus": {
      "type": "stdio",
      "command": "node",
      "args": ["~/.local/share/contextplus-patched/build/index.js"],
      "env": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
        "OPENROUTER_EMBED_MODEL": "openai/text-embedding-3-small",
        "CONTEXTPLUS_EMBED_PROVIDER": "auto"
      }
    },
    "serena": {
      "type": "stdio",
      "command": "serena",
      "args": []
    },
    "llm-tldr": {
      "type": "stdio",
      "command": "tldr-mcp",
      "args": []
    }
  }
}
