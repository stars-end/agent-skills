{
  "mcpServers": {
    "context-plus-agent-skills": {
      "type": "stdio",
      "command": "node",
      "args": [
        "~/.local/share/contextplus-patched/build/index.js",
        "~/agent-skills"
      ],
      "env": {
        "OPENROUTER_EMBED_MODEL": "openai/text-embedding-3-small",
        "CONTEXTPLUS_EMBED_PROVIDER": "auto"
      }
    },
    "context-plus-prime-radiant-ai": {
      "type": "stdio",
      "command": "node",
      "args": [
        "~/.local/share/contextplus-patched/build/index.js",
