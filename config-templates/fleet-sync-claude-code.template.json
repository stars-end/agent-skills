      ],
      "env": {
        "OPENROUTER_EMBED_MODEL": "openai/text-embedding-3-small",
        "CONTEXTPLUS_EMBED_PROVIDER": "auto"
      }
    },
    "context-plus-llm-common": {
      "type": "stdio",
