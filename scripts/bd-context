#!/usr/bin/env bash
# bd-context - Print current repo + Beads context (safe, no secrets).
#
# Usage:
#   bd-context
#
# Output includes:
# - repo root + origin URL (if any)
# - current branch
# - best-effort Beads issue ID inferred from branch name

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
REPO_NAME="$(basename -- "$REPO_ROOT")"
REMOTE_URL="$(git -C "$REPO_ROOT" remote get-url origin 2>/dev/null || echo "")"
BRANCH="$(git -C "$REPO_ROOT" branch --show-current 2>/dev/null || echo "")"

if [[ -z "$BRANCH" ]]; then
  BRANCH="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
fi

BEADS_ID=""
if [[ -n "$BRANCH" ]]; then
  BRANCH_CONTEXT="${BRANCH##*/}"
  if [[ "$BRANCH_CONTEXT" == feature-* ]]; then
    BRANCH_CONTEXT="${BRANCH_CONTEXT#feature-}"
  fi
  if [[ "$BRANCH_CONTEXT" =~ ^([a-z][a-z0-9]*-[a-z0-9]+(\.[a-z0-9]+)*)$ ]]; then
    BEADS_ID="${BASH_REMATCH[1]}"
  else
    BEADS_ID="$(echo "$BRANCH" | rg -o '[a-z][a-z0-9]*-[a-z0-9]+(\.[a-z0-9]+)*' 2>/dev/null | head -1 || true)"
  fi
fi

echo "repo_root: $REPO_ROOT"
if [[ -n "$REMOTE_URL" ]]; then
  echo "origin:    $REMOTE_URL"
fi
if [[ -n "$BRANCH" ]]; then
  echo "branch:    $BRANCH"
fi
if [[ -n "$BEADS_ID" ]]; then
  echo "beads_id:  $BEADS_ID"
fi

if [[ "$REPO_NAME" == "agent-skills" && -n "$BEADS_ID" && ! "$BEADS_ID" =~ ^bd-[a-z0-9]+(\.[a-z0-9]+)*$ ]]; then
  cat >&2 <<EOF

❌ INCOMPATIBLE BEADS CONTEXT

repo:      $REPO_NAME
branch:    $BRANCH
beads_id:  $BEADS_ID

$REPO_NAME requires repo-compatible bd-* Feature-Keys and branch ids.
This context must be corrected before commit or PR steps.

Next steps:
  1. Create or choose the correct bd-* issue for this $REPO_NAME work.
  2. Rename the branch to feature-bd-<issue>.
  3. Re-run bd-context and continue only after it reports a bd-* id.

EOF
  exit 2
fi

if command -v bd >/dev/null 2>&1; then
  if [[ -n "$BEADS_ID" && "$BEADS_ID" =~ ^bd-[a-z0-9]+(\.[a-z0-9]+)*$ ]]; then
    echo ""
    echo "bd show $BEADS_ID (summary):"
    bd show "$BEADS_ID" 2>/dev/null | head -20 || true
  fi
else
  echo ""
  echo "note: bd CLI not found"
fi
