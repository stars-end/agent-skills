#!/usr/bin/env bash
set -euo pipefail

CANONICAL_BEADS_DIR="${BDX_BEADS_DIR:-$HOME/.beads-runtime/.beads}"
REMOTE_HOST="${BDX_REMOTE_HOST:-epyc12}"
REMOTE_HELPER="${BDX_REMOTE_HELPER:-\$HOME/agent-skills/scripts/bdx-remote}"
SSH_BIN="${BDX_SSH_BIN:-ssh}"
HOSTNAME_SHORT="${BDX_HOSTNAME:-$(hostname -s 2>/dev/null || hostname)}"
SSH_CONNECT_TIMEOUT="${BDX_SSH_CONNECT_TIMEOUT_SECONDS:-${BDX_SSH_CONNECT_TIMEOUT:-5}}"
WANT_JSON_ERRORS=0

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  local dir

  while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" == /* ]] || source="$dir/$source"
  done

  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"

usage() {
  cat >&2 <<'EOF'
Usage:
  bdx <command> [args...]

Canonical coordination commands:
  Reads: show, ready, list, search, comments, memories, recall, config get|list, dolt test
  Writes: create, comments add, note, update, close, reopen, dep, label, epic, batch, remember, forget
  Health: preflight --json

Local only / rejected:
  init, where, context, doctor, dolt start|stop|set, unknown commands
EOF
}

usage_create() {
  cat >&2 <<'EOF'
Usage:
  bdx create --title "Task" --type task [flags...]
  bdx create "Task title" [flags...]

Common agent-safe flags:
  --title, --description, --type, --priority, --parent, --deps, --labels,
  --metadata, --notes, --acceptance, --id, --force, --json

BDX safety overrides:
  --repo / --repo=<name> is rejected on mutating bdx writes
  (reason_code=repo_flag_unsupported) because Beads target-repo
  initialization can fall back to embedded Dolt. Use labels, metadata, or cwd
  context to express repo intent instead.

Path-sensitive flags such as --body-file, --description-file, --graph, and
--stdin are rejected on spoke hosts. Use inline values or run directly on
epyc12 for path-sensitive diagnostics.
EOF
}

usage_comments_add() {
  cat >&2 <<'EOF'
Usage:
  bdx comments add <issue-id> "comment text"
  bdx comments add <issue-id> -f notes.txt

Do not use --body with bdx comments add. Comment text is positional, or use
-f/--file when running directly on a host that can read that file.
EOF
}

json_string() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
}

emit_json_error() {
  local reason_code="$1"
  local message="$2"
  local command="${3:-${1:-}}"
  local host="${4:-$REMOTE_HOST}"
  printf '{"ok":false,"reason_code":%s,"message":%s,"command":%s,"host":%s}\n' \
    "$(printf '%s' "$reason_code" | json_string)" \
    "$(printf '%s' "$message" | json_string)" \
    "$(printf '%s' "$command" | json_string)" \
    "$(printf '%s' "$host" | json_string)" >&2
}

die() {
  local reason_code="invalid_usage"
  local message

  if [[ $# -ge 2 ]]; then
    reason_code="$1"
    shift
  fi
  message="$*"

  if [[ "$WANT_JSON_ERRORS" == "1" || "${BDX_JSON_ERRORS:-0}" == "1" ]]; then
    emit_json_error "$reason_code" "bdx: $message" "${BDX_COMMAND_NAME:-${1:-}}"
  else
    echo "bdx: $message" >&2
  fi
  exit 2
}

detect_json_errors() {
  local arg
  WANT_JSON_ERRORS="${BDX_JSON_ERRORS:-0}"
  for arg in "$@"; do
    if [[ "$arg" == "--json" ]]; then
      WANT_JSON_ERRORS=1
      return 0
    fi
  done
}

remote_host_key() {
  local host="${REMOTE_HOST##*@}"
  host="${host%%.*}"
  printf '%s' "$host"
}

is_hub_host() {
  local remote_key
  remote_key="$(remote_host_key)"

  if [[ "${BDX_FORCE_LOCAL:-0}" == "1" ]]; then
    return 0
  fi

  if [[ "$HOSTNAME_SHORT" == "$remote_key" || "$HOSTNAME_SHORT" == "$REMOTE_HOST" ]]; then
    return 0
  fi

  if command -v tailscale >/dev/null 2>&1; then
    local ts_status
    ts_status="$(tailscale status --json 2>/dev/null || true)"
    local self_names=""
    if command -v python3 >/dev/null 2>&1; then
      self_names="$(printf '%s' "$ts_status" | python3 -c 'import json,sys
try:
    self_node=json.load(sys.stdin).get("Self", {})
except Exception:
    self_node={}
for key in ("HostName", "DNSName"):
    value=self_node.get(key)
    if value:
        print(value)
' 2>/dev/null || true)"
    fi
    if printf '%s\n' "$self_names" | grep -Eq "^${remote_key}(\\.|$)"; then
      return 0
    fi
  fi

  return 1
}

emit_argv() {
  printf '%s\0' "$@"
}

classify_command() {
  local cmd="${1:-}"
  local sub="${2:-}"
  local third="${3:-}"

  case "$cmd" in
    create|note|update|close|reopen|dep|label|epic|batch|remember|forget)
      echo "write"
      return 0
      ;;
    show|ready|list|search|memories|recall)
      echo "read"
      return 0
      ;;
    comments)
      case "$sub" in
        add)
          echo "write"
          ;;
        ""|list|show|bd-*)
          echo "read"
          ;;
        *)
          die unsupported_command "rejected comments subcommand '$sub' (allowed: add, list, show, <issue-id>)"
          ;;
      esac
      return 0
      ;;
    config)
      case "$sub" in
        get|list)
          echo "read"
          return 0
          ;;
        *)
          die unsupported_command "rejected risky config subcommand '$sub' (allowed: get, list)"
          ;;
      esac
      ;;
    dolt)
      case "$sub" in
        test)
          echo "read"
          return 0
          ;;
        start|stop|set)
          die unsupported_command "rejected local-only dolt subcommand '$sub'"
          ;;
        *)
          die unsupported_command "rejected dolt subcommand '$sub' (allowed via bdx: test)"
          ;;
      esac
      ;;
    init|where|context|doctor)
      die unsupported_command "rejected local-only command '$cmd'"
      ;;
    help|-h|--help|"")
      usage
      exit 0
      ;;
    *)
      die unsupported_command "rejected unknown command '$cmd'"
      ;;
  esac

  # Unreachable; keeps shellcheck calm on exhaustive return paths.
  [[ "$third" == "__never__" ]]
}

run_local() {
  local mode="$1"
  shift

  emit_argv "$@" | BDX_BEADS_DIR="$CANONICAL_BEADS_DIR" "$SCRIPT_DIR/bdx-remote" "--mode=$mode"
}

run_remote() {
  local mode="$1"
  shift
  local rc
  local err_file=""
  local ssh_opts=(
    -o "BatchMode=yes"
    -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}"
    -o "StrictHostKeyChecking=accept-new"
  )

  # NUL-delimited argv transport: user arguments never touch remote shell parsing.
  if [[ "$WANT_JSON_ERRORS" == "1" || "${BDX_JSON_ERRORS:-0}" == "1" ]]; then
    err_file="$(mktemp)"
    set +e
    emit_argv "$@" | "$SSH_BIN" "${ssh_opts[@]}" "$REMOTE_HOST" "$REMOTE_HELPER" "--mode=$mode" 2> >(tee "$err_file" >&2)
    rc=${PIPESTATUS[1]}
    set -e
    if [[ "$rc" -eq 255 ]]; then
      if ! grep -Fq '"reason_code":"ssh_unreachable"' "$err_file" 2>/dev/null; then
        emit_json_error "ssh_unreachable" "bdx remote host is unreachable" "${BDX_COMMAND_NAME:-${1:-}}" "$REMOTE_HOST"
      fi
    elif [[ "$rc" -ne 0 ]]; then
      if ! grep -Fq '"reason_code":' "$err_file" 2>/dev/null; then
        emit_json_error "remote_bd_failed" "bdx remote command failed with exit code $rc" "${BDX_COMMAND_NAME:-${1:-}}" "$REMOTE_HOST"
      fi
    fi
    rm -f "$err_file"
    return "$rc"
  fi

  set +e
  emit_argv "$@" | "$SSH_BIN" "${ssh_opts[@]}" "$REMOTE_HOST" "$REMOTE_HELPER" "--mode=$mode"
  rc=${PIPESTATUS[1]}
  set -e
  if [[ "$rc" -eq 255 ]]; then
    echo "bdx: remote host '$REMOTE_HOST' is unreachable" >&2
  fi
  return "$rc"
}

find_flag_match() {
  local needle="$1"
  shift
  local arg
  for arg in "$@"; do
    if [[ "$arg" == "$needle" || "$arg" == "$needle="* ]]; then
      printf '%s' "$needle"
      return 0
    fi
  done
  return 1
}

find_metadata_file_arg() {
  local arg next
  while [[ $# -gt 0 ]]; do
    arg="$1"
    shift
    case "$arg" in
      --metadata=@*)
        printf '%s' "$arg"
        return 0
        ;;
      --metadata)
        next="${1:-}"
        if [[ "$next" == @* ]]; then
          printf '%s %s' "$arg" "$next"
          return 0
        fi
        ;;
    esac
  done
  return 1
}

preflight_remote_write() {
  local cmd="$1"
  shift

  local file_flag=""
  local candidate
  for candidate in --body-file --description-file --design-file --file --graph --stdin; do
    if file_flag="$(find_flag_match "$candidate" "$@")"; then
      if [[ "$candidate" == "--stdin" ]]; then
        die local_file_arg_unsupported "remote bdx write rejected: '--stdin' body streaming is not supported over remote routing. Use inline body flags or run from epyc12."
      fi
      die local_file_arg_unsupported "remote bdx write rejected: local file-bearing flag '$file_flag' is not supported over remote routing. Use inline values or run from epyc12."
    fi
  done

  local metadata_file_arg
  if metadata_file_arg="$(find_metadata_file_arg "$@")"; then
    die local_file_arg_unsupported "remote bdx write rejected: metadata file expansion '$metadata_file_arg' is not supported over remote routing. Use inline --metadata key=value or run from epyc12."
  fi
}

preflight_write_repo_flag() {
  local repo_flag=""
  if repo_flag="$(find_flag_match --repo "$@")"; then
    die repo_flag_unsupported "bdx write rejected: '$repo_flag' is unsupported on mutating commands because Beads target-repo initialization can fall back to embedded Dolt. Use labels/metadata/cwd context instead."
  fi
}

preflight_comments_add_body_flag() {
  [[ "${1:-}" == "comments" && "${2:-}" == "add" ]] || return 0

  local body_flag=""
  if body_flag="$(find_flag_match --body "$@")"; then
    die comments_body_unsupported "bdx comments add rejected: '$body_flag' is not supported. Comment text is positional: bdx comments add <issue-id> \"comment text\". Use -f/--file only when the file is readable by the command host."
  fi
}

main() {
  [[ $# -gt 0 ]] || { usage; exit 2; }
  detect_json_errors "$@"
  BDX_COMMAND_NAME="${1:-}"

  case "${1:-}" in
    preflight)
      shift
      exec "$SCRIPT_DIR/bdx-preflight" "$@"
      ;;
    help|-h|--help)
      usage
      exit 0
      ;;
  esac

  if [[ "${1:-}" == "create" && ( "${2:-}" == "--help" || "${2:-}" == "-h" ) ]]; then
    usage_create
    exit 0
  fi

  if [[ "${1:-}" == "comments" && "${2:-}" == "add" && ( "${3:-}" == "--help" || "${3:-}" == "-h" ) ]]; then
    usage_comments_add
    exit 0
  fi

  local mode
  mode="$(classify_command "$@")"

  if [[ "$mode" == "write" ]]; then
    preflight_comments_add_body_flag "$@"
    preflight_write_repo_flag "$@"
  fi

  if is_hub_host; then
    run_local "$mode" "$@"
  else
    if [[ "$mode" == "write" ]]; then
      preflight_remote_write "$@"
    fi
    run_remote "$mode" "$@"
  fi
}

main "$@"
