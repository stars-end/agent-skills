# Nightly enrichment job environment
# Source: op://dev/Agent-Secrets-Production/
#
# ZAI_API_KEY is resolved at runtime by the cron wrapper via cached OP
# resolution (dx_auth_load_zai_api_key). Do NOT set it manually here.
#
# For manual/interactive use:
#   source scripts/lib/dx-auth.sh && dx_auth_load_zai_api_key
#   python3 scripts/enrichment/nightly-enrichment.py
#
# For cron:
#   0 3 * * * /path/to/agent-skills/scripts/enrichment/enrichment-cron-wrapper.sh

ZAI_API_KEY=<resolved by enrichment-cron-wrapper.sh via dx_auth_load_zai_api_key>
ZAI_MODEL=glm-4.7
ENRICHMENT_BATCH=20
ENRICHMENT_TIMEOUT=30
ENRICHMENT_ARTIFACT_ROOT=~/.dx-state/enrichment/
