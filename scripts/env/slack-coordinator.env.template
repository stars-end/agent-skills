# ============================================================
# System Environment
# ============================================================

PATH="/home/linuxbrew/.linuxbrew/bin:/usr/local/bin:/usr/bin:/bin"
HOME="${HOME}"

# ============================================================
# Python Environment
# ============================================================

PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
