#!/usr/bin/env bash
set -euo pipefail

CANONICAL_BEADS_DIR="${BDX_BEADS_DIR:-$HOME/.beads-runtime/.beads}"
LOCK_TIMEOUT_SECONDS="${BDX_LOCK_TIMEOUT_SECONDS:-15}"
READ_TIMEOUT_SECONDS="${BDX_READ_TIMEOUT_SECONDS:-10}"
WRITE_TIMEOUT_SECONDS="${BDX_WRITE_TIMEOUT_SECONDS:-30}"
LOCK_ROOT="${BDX_LOCK_ROOT:-$HOME/.beads-runtime/.locks}"
LOCK_NAME="${BDX_LOCK_NAME:-bdx-mutate.lock}"
LOCK_PATH="$LOCK_ROOT/$LOCK_NAME"
WANT_JSON_ERRORS="${BDX_JSON_ERRORS:-0}"

if [[ -n "${BDX_COMMAND_TIMEOUT_SECONDS:-}" ]]; then
  READ_TIMEOUT_SECONDS="${BDX_COMMAND_TIMEOUT_SECONDS}"
  WRITE_TIMEOUT_SECONDS="${BDX_COMMAND_TIMEOUT_SECONDS}"
fi

json_string() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
}

emit_json_error() {
  local reason_code="$1"
  local message="$2"
  local command="${3:-${args[0]:-}}"
  local host
  host="$(hostname -s 2>/dev/null || hostname)"
  printf '{"ok":false,"reason_code":%s,"message":%s,"command":%s,"host":%s}\n' \
    "$(printf '%s' "$reason_code" | json_string)" \
    "$(printf '%s' "$message" | json_string)" \
    "$(printf '%s' "$command" | json_string)" \
    "$(printf '%s' "$host" | json_string)" >&2
}

die() {
  local reason_code="invalid_usage"
  local message
  if [[ $# -ge 2 ]]; then
    reason_code="$1"
    shift
  fi
  message="$*"

  if [[ "$WANT_JSON_ERRORS" == "1" ]]; then
    emit_json_error "$reason_code" "bdx-remote: $message"
  else
    echo "bdx-remote: $message" >&2
  fi
  exit 2
}

classify_command() {
  local cmd="${1:-}"
  local sub="${2:-}"

  case "$cmd" in
    create|note|update|close|reopen|dep|label|epic|batch|remember|forget)
      echo "write"
      return 0
      ;;
    show|ready|list|search|memories|recall)
      echo "read"
      return 0
      ;;
    comments)
      case "$sub" in
        add)
          echo "write"
          ;;
        ""|list|show|bd-*)
          echo "read"
          ;;
        *)
          die unsupported_command "rejected comments subcommand '$sub' (allowed: add, list, show, <issue-id>)"
          ;;
      esac
      return 0
      ;;
    config)
      case "$sub" in
        get|list)
          echo "read"
          return 0
          ;;
        *)
          die unsupported_command "rejected risky config subcommand '$sub' (allowed: get, list)"
          ;;
      esac
      ;;
    dolt)
      case "$sub" in
        test)
          echo "read"
          return 0
          ;;
        start|stop|set)
          die unsupported_command "rejected local-only dolt subcommand '$sub'"
          ;;
        *)
          die unsupported_command "rejected dolt subcommand '$sub' (allowed via bdx: test)"
          ;;
      esac
      ;;
    init|where|context|doctor)
      die unsupported_command "rejected local-only command '$cmd'"
      ;;
    help|-h|--help|"")
      die invalid_usage "help must be handled by bdx, not bdx-remote"
      ;;
    *)
      die unsupported_command "rejected unknown command '$cmd'"
      ;;
  esac
}

mode="read"
for arg in "$@"; do
  case "$arg" in
    --mode=read|--mode=write)
      mode="${arg#--mode=}"
      ;;
    *)
      die invalid_usage "unsupported argument '$arg'"
      ;;
  esac
done

args=()
while IFS= read -r -d '' item; do
  args+=("$item")
done

[[ ${#args[@]} -gt 0 ]] || die "missing command argv on stdin"
for arg in "${args[@]}"; do
  if [[ "$arg" == "--json" ]]; then
    WANT_JSON_ERRORS=1
    break
  fi
done

actual_mode="$(classify_command "${args[@]}")"
if [[ "$actual_mode" != "$mode" ]]; then
  die invalid_usage "client mode '$mode' does not match command mode '$actual_mode'"
fi

run_bd_with_timeout() {
  local timeout_seconds="$1"
  local pid waited rc

  if ! command -v bd >/dev/null 2>&1; then
    die remote_bd_missing "bd executable not found on remote host"
  fi

  if command -v timeout >/dev/null 2>&1; then
    set +e
    env BEADS_DIR="$CANONICAL_BEADS_DIR" timeout "${timeout_seconds}s" bd "${args[@]}"
    rc=$?
    set -e
    if [[ "$rc" -eq 124 || "$rc" -eq 137 ]]; then
      if [[ "$mode" == "write" ]]; then
        die mutation_timeout "bd command timed out after ${timeout_seconds}s"
      fi
      die query_timeout "bd command timed out after ${timeout_seconds}s"
    fi
    return "$rc"
  fi

  BEADS_DIR="$CANONICAL_BEADS_DIR" bd "${args[@]}" &
  pid="$!"
  waited=0
  while kill -0 "$pid" >/dev/null 2>&1; do
    if (( waited >= timeout_seconds )); then
      kill "$pid" >/dev/null 2>&1 || true
      wait "$pid" >/dev/null 2>&1 || true
      if [[ "$mode" == "write" ]]; then
        die mutation_timeout "bd command timed out after ${timeout_seconds}s"
      fi
      die query_timeout "bd command timed out after ${timeout_seconds}s"
    fi
    sleep 1
    waited=$((waited + 1))
  done
  set +e
  wait "$pid"
  rc=$?
  set -e
  return "$rc"
}

run_with_mkdir_lock() {
  local lockdir="${LOCK_PATH}.dir"
  local deadline=$((SECONDS + LOCK_TIMEOUT_SECONDS))

  mkdir -p "$LOCK_ROOT"
  while ! mkdir "$lockdir" 2>/dev/null; do
    if (( SECONDS >= deadline )); then
      die lock_timeout "timed out acquiring lock: $lockdir"
    fi
    sleep 0.1
  done

  trap "rmdir '$lockdir' 2>/dev/null || true" EXIT
  run_bd_with_timeout "$WRITE_TIMEOUT_SECONDS"
}

run_with_flock() {
  local rc

  if ! command -v bd >/dev/null 2>&1; then
    die remote_bd_missing "bd executable not found on remote host"
  fi

  set +e
  flock -w "$LOCK_TIMEOUT_SECONDS" "$LOCK_PATH" \
    env BEADS_DIR="$CANONICAL_BEADS_DIR" timeout "${WRITE_TIMEOUT_SECONDS}s" bd "${args[@]}"
  rc=$?
  set -e

  if [[ "$rc" -eq 124 || "$rc" -eq 137 ]]; then
    die mutation_timeout "bd command timed out after ${WRITE_TIMEOUT_SECONDS}s"
  fi

  return "$rc"
}

run_command() {
  local rc

  if [[ "$mode" == "write" ]]; then
    mkdir -p "$LOCK_ROOT"
    if [[ "${BDX_DISABLE_FLOCK:-0}" != "1" ]] && command -v flock >/dev/null 2>&1 && command -v timeout >/dev/null 2>&1; then
      run_with_flock
      return $?
    fi
    run_with_mkdir_lock
    return $?
  fi

  run_bd_with_timeout "$READ_TIMEOUT_SECONDS"
  rc=$?
  return "$rc"
}

set +e
run_command
rc=$?
set -e

if [[ "$rc" -ne 0 && "$WANT_JSON_ERRORS" == "1" ]]; then
  emit_json_error "remote_bd_failed" "bd command failed with exit code $rc"
fi
exit "$rc"
