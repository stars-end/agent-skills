#!/usr/bin/env python3
"""Scheduled/default-branch audit for repo-owned architecture maps."""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from datetime import datetime, timezone
from fnmatch import fnmatchcase
from pathlib import Path


def _run_git(repo: Path, args: list[str]) -> tuple[int, str, str]:
    try:
        out = subprocess.run(
            ["git", *args],
            cwd=str(repo),
            text=True,
            capture_output=True,
            check=False,
        )
        return out.returncode, out.stdout.strip(), out.stderr.strip()
    except (FileNotFoundError, OSError) as exc:
        return 1, "", str(exc)


def _normalize(path: str) -> str:
    value = path.replace("\\", "/")
    while value.startswith("./"):
        value = value[2:]
    return value


def _parse_frontmatter(path: Path) -> tuple[dict[str, object] | None, str | None]:
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return None, f"cannot read file: {exc}"

    lines = text.splitlines()
    if len(lines) < 3 or lines[0].strip() != "---":
        return None, "missing opening frontmatter delimiter"

    end = None
    for index in range(1, len(lines)):
        if lines[index].strip() == "---":
            end = index
            break
    if end is None:
        return None, "missing closing frontmatter delimiter"

    data: dict[str, object] = {}
    raw = lines[1:end]
    i = 0
    while i < len(raw):
        line = raw[i]
        if not line.strip() or line.strip().startswith("#"):
            i += 1
            continue
        if ":" not in line:
            return None, f"invalid frontmatter line: {line!r}"
        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()
        if not key:
            return None, f"invalid key in frontmatter line: {line!r}"
        if value:
            data[key] = value
            i += 1
            continue

        items: list[str] = []
        i += 1
        while i < len(raw):
            candidate = raw[i]
            if candidate.startswith("  - "):
                item = candidate[4:].strip()
                if item:
                    items.append(item)
                i += 1
                continue
            if candidate.startswith("    - "):
                item = candidate[6:].strip()
                if item:
                    items.append(item)
                i += 1
                continue
            if not candidate.strip():
                i += 1
                continue
            if re.match(r"^[A-Za-z0-9_.-]+\s*:", candidate):
                break
            return None, f"invalid list item syntax near line: {candidate!r}"
        data[key] = items

    return data, None


def _parse_datetime(value: str) -> datetime | None:
    raw = value.strip()
    if not raw:
        return None
    if raw.endswith("Z"):
        raw = raw[:-1] + "+00:00"
    try:
        dt = datetime.fromisoformat(raw)
    except ValueError:
        try:
            dt = datetime.fromisoformat(raw + "T00:00:00+00:00")
        except ValueError:
            return None
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt.astimezone(timezone.utc)


def _changed_since(repo: Path, start_commit: str) -> tuple[list[str], str | None]:
    rc, _, err = _run_git(repo, ["cat-file", "-e", f"{start_commit}^{{commit}}"])
    if rc != 0:
        return [], err or "last_verified_commit is not a valid commit"

    rc, out, err = _run_git(repo, ["diff", "--name-only", f"{start_commit}..HEAD"])
    if rc != 0:
        return [], err or "git diff failed"
    return sorted({_normalize(line) for line in out.splitlines() if line.strip()}), None


def _agents_link_status(repo: Path, docs: list[str]) -> list[dict[str, str]]:
    failures: list[dict[str, str]] = []
    agents = repo / "AGENTS.local.md"
    if not agents.exists():
        agents = repo / "AGENTS.md"
    if not agents.exists():
        return [{"file": "AGENTS.local.md|AGENTS.md", "reason": "missing AGENTS file"}]
    try:
        text = agents.read_text(encoding="utf-8")
    except OSError as exc:
        return [{"file": _normalize(str(agents.relative_to(repo))), "reason": str(exc)}]

    for doc in docs:
        if doc not in text:
            failures.append(
                {
                    "file": _normalize(str(agents.relative_to(repo))),
                    "doc": doc,
                    "reason": "AGENTS file does not link repo-memory doc",
                }
            )
    return failures


def main() -> int:
    parser = argparse.ArgumentParser(description="Audit repo-memory maps for scheduled refresh.")
    parser.add_argument("--repo", required=True, help="Path to repository root")
    parser.add_argument("--json", action="store_true", dest="json_output", help="Emit JSON output")
    parser.add_argument("--age-days", type=int, default=30, help="Warn when last_verified_at is older than this")
    parser.add_argument("--allow-missing", action="store_true", help="Allow repos with no docs/architecture maps")
    args = parser.parse_args()

    repo = Path(args.repo).resolve()
    if not repo.exists() or not repo.is_dir():
        print(f"ERROR: repo path does not exist: {repo}", file=sys.stderr)
        return 2

    rc, head, err = _run_git(repo, ["rev-parse", "HEAD"])
    if rc != 0:
        print(f"ERROR: cannot resolve HEAD: {err}", file=sys.stderr)
        return 2

    doc_dir = repo / "docs" / "architecture"
    docs = sorted(path for path in doc_dir.glob("*.md") if path.is_file())
    checked_docs = [_normalize(str(path.relative_to(repo))) for path in docs]
    now = datetime.now(timezone.utc)

    doc_reports: list[dict[str, object]] = []
    frontmatter_failures: list[dict[str, str]] = []
    stale_docs: list[dict[str, object]] = []
    age_warnings: list[dict[str, object]] = []

    checked_doc_set = set(checked_docs)
    required = ("status", "owner", "last_verified_commit", "last_verified_at", "stale_if_paths")
    for path in docs:
        rel = _normalize(str(path.relative_to(repo)))
        fm, fm_error = _parse_frontmatter(path)
        if fm_error or fm is None:
            failure = {"doc": rel, "reason": fm_error or "cannot parse frontmatter"}
            frontmatter_failures.append(failure)
            doc_reports.append({"doc": rel, "status": "invalid", "frontmatter_failure": failure})
            continue

        missing = [key for key in required if key not in fm]
        stale_if_paths = fm.get("stale_if_paths")
        if missing:
            failure = {"doc": rel, "reason": f"missing required keys: {', '.join(missing)}"}
            frontmatter_failures.append(failure)
            doc_reports.append({"doc": rel, "status": "invalid", "frontmatter_failure": failure})
            continue
        if not isinstance(stale_if_paths, list) or not stale_if_paths:
            failure = {"doc": rel, "reason": "stale_if_paths must be a non-empty list"}
            frontmatter_failures.append(failure)
            doc_reports.append({"doc": rel, "status": "invalid", "frontmatter_failure": failure})
            continue

        last_commit = str(fm.get("last_verified_commit", "")).strip()
        changed, diff_error = _changed_since(repo, last_commit)
        matched_changes = [
            changed_path
            for changed_path in changed
            if changed_path not in checked_doc_set
            and any(fnmatchcase(changed_path, str(pattern).strip()) for pattern in stale_if_paths)
        ]

        stale = bool(matched_changes) or bool(diff_error)
        age_days = None
        last_verified_at = str(fm.get("last_verified_at", "")).strip()
        parsed_dt = _parse_datetime(last_verified_at)
        if parsed_dt is not None:
            age_days = (now - parsed_dt).days
        age_stale = age_days is not None and age_days > args.age_days

        report: dict[str, object] = {
            "doc": rel,
            "owner": fm.get("owner"),
            "last_verified_commit": last_commit,
            "last_verified_at": last_verified_at,
            "age_days": age_days,
            "age_threshold_days": args.age_days,
            "stale_if_paths": stale_if_paths,
            "changed_files_since_last_verified": changed,
            "matched_changes": matched_changes,
            "diff_error": diff_error,
            "stale_by_paths": bool(matched_changes),
            "stale_by_age": age_stale,
            "needs_refresh": stale or age_stale,
        }
        doc_reports.append(report)
        if stale:
            stale_docs.append(report)
        if age_stale:
            age_warnings.append(report)

    link_failures = _agents_link_status(repo, checked_docs) if docs else []

    status = "pass"
    if frontmatter_failures or link_failures:
        status = "fail"
    elif stale_docs or age_warnings:
        status = "stale"
    elif not docs and not args.allow_missing:
        status = "fail"
        frontmatter_failures.append({"doc": "docs/architecture/*.md", "reason": "no repo-memory docs discovered"})

    payload = {
        "status": status,
        "action_needed": status in {"stale", "fail"},
        "repo": str(repo),
        "head": head,
        "checked_docs": checked_docs,
        "docs": doc_reports,
        "stale_docs": stale_docs,
        "age_warnings": age_warnings,
        "frontmatter_failures": frontmatter_failures,
        "link_failures": link_failures,
        "summary": {
            "docs": len(checked_docs),
            "stale_docs": len(stale_docs),
            "age_warnings": len(age_warnings),
            "frontmatter_failures": len(frontmatter_failures),
            "link_failures": len(link_failures),
        },
    }

    if args.json_output:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(
            f"dx-repo-memory-audit: {status.upper()} "
            f"(docs={len(checked_docs)}, stale={len(stale_docs)}, age={len(age_warnings)}, "
            f"fm={len(frontmatter_failures)}, links={len(link_failures)})"
        )
        for item in stale_docs:
            print(f"  - stale: {item['doc']}")
        for item in age_warnings:
            print(f"  - age: {item['doc']} ({item.get('age_days')}d)")
        for item in frontmatter_failures:
            print(f"  - frontmatter: {item.get('doc')}: {item.get('reason')}")
        for item in link_failures:
            print(f"  - link: {item.get('file')}: {item.get('doc', '')} {item.get('reason')}")

    return 0 if status == "pass" else (1 if status == "stale" else 2)


if __name__ == "__main__":
    sys.exit(main())
