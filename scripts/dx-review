#!/usr/bin/env bash
set -euo pipefail

# dx-review
# Minimal review quorum wrapper over dx-runner profiles.
# Default reviewers:
#   - claude-code-review -> Claude Code Opus
#   - cc-glm-review      -> GLM-5 via cc-glm transport
# Fallback:
#   - opencode-review    -> OpenCode GLM-5.1 if cc-glm fails at start/preflight

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
if [[ -L "$SCRIPT_SOURCE" ]]; then
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
DX_RUNNER="${DX_RUNNER_BIN:-$SCRIPT_DIR/dx-runner}"
TEMPLATES_DIR="${DX_REVIEW_TEMPLATES_DIR:-$SCRIPT_DIR/../templates/dx-review}"

usage() {
    cat <<'EOF'
dx-review

Usage:
  dx-review run --beads <bd-id> --worktree <path> (--prompt <text> | --prompt-file <path> | --template <name> | --pr <ref>) [options]
  dx-review doctor --worktree <path> [--gemini]
  dx-review summarize --beads <bd-id> [--gemini]

Options:
  --gemini              Include the optional gemini-burst reviewer.
  --pr <url|repo#num>   Include GitHub PR metadata from gh.
  --github-pr <ref>     Alias for --pr.
  --template <name>     Review template: smoke, code-review, architecture-review, arch-review, security-review.
  --read-only-shell     Include explicit read-only shell review contract.
  --wait                Wait for reviewers to finish.
  --timeout-sec <n>     Wait timeout in seconds (default: 300).
  --poll-sec <n>        Poll interval in seconds (default: 5).

Examples:
  dx-review run --beads bd-xxx --worktree /tmp/agents/bd-xxx/agent-skills \
    --pr https://github.com/stars-end/agent-skills/pull/554 \
    --template code-review --wait
  dx-review summarize --beads bd-xxx
EOF
}

require_bash() {
    if [[ -z "${BASH_VERSION:-}" ]] || (( ${BASH_VERSINFO[0]:-0} < 4 )); then
        echo "dx-review requires bash >= 4." >&2
        exit 2
    fi
}

valid_beads_id() {
    local id="$1"
    [[ "$id" =~ ^bd-[a-z0-9]+(\.[a-z0-9]+)*$ ]]
}

json_escape() {
    local s="${1:-}"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

reviewer_id_for_profile() {
    local beads="$1"
    local profile="$2"
    case "$profile" in
        claude-code-review) printf '%s.claude' "$beads" ;;
        cc-glm-review) printf '%s.glm' "$beads" ;;
        opencode-review) printf '%s.opencode' "$beads" ;;
        gemini-burst) printf '%s.gemini' "$beads" ;;
        *) printf '%s.%s' "$beads" "$(printf '%s' "$profile" | tr -cd 'a-z0-9')" ;;
    esac
}

state_from_check_json() {
    sed -n 's/.*"state"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1
}

review_state_for_display() {
    case "$1" in
        no_op_success) printf 'review_completed' ;;
        start_failed) printf 'start_failed' ;;
        *) printf '%s' "$1" ;;
    esac
}

is_terminal_state() {
    case "$1" in
        exited_ok|exited_err|no_op_success|stopped|blocked|missing|start_failed)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

reason_from_json() {
    sed -n 's/.*"reason_code"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1
}

reason_from_start_log() {
    local text="${1:-}"
    local value=""
    value="$(printf '%s\n' "$text" | reason_from_json)"
    if [[ -z "$value" ]]; then
        value="$(printf '%s\n' "$text" | sed -n 's/.*reason_code[=:][[:space:]]*\([^[:space:]]*\).*/\1/p' | head -n 1)"
    fi
    if [[ -z "$value" ]]; then
        case "$text" in
            *canonical_model_probe_timeout*|*"model probe timed out"*|*"probe timed out"*)
                value="canonical_model_probe_timeout"
                ;;
            *model_unavailable*|*"model unavailable"*)
                value="model_unavailable"
                ;;
            *auth_or_quota_blocked*|*"auth or quota"*)
                value="auth_or_quota_blocked"
                ;;
            *mise_untrusted*)
                value="opencode_mise_untrusted"
                ;;
            *preflight*failed*)
                value="provider_preflight_failed"
                ;;
        esac
    fi
    printf '%s' "$value"
}

provider_from_json() {
    sed -n 's/.*"provider"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1
}

verdict_from_text() {
    local text="${1:-}"
    local verdict=""
    verdict="$(printf '%s\n' "$text" | sed -n 's/.*"verdict"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
    if [[ -z "$verdict" ]]; then
        verdict="$(printf '%s\n' "$text" | sed -E -n 's/^[*[:space:]]*VERDICT:[*[:space:]]*([^*[:space:]]+).*$/\1/p' | head -n 1)"
    fi
    printf '%s' "$verdict"
}

json_number_from_text() {
    local key="$1"
    local text="${2:-}"
    local value
    value="$(printf '%s\n' "$text" | sed -n "s/.*\"${key}\"[[:space:]]*:[[:space:]]*\"\\{0,1\\}\\([-0-9.][0-9.]*\\)\"\\{0,1\\}.*/\\1/p" | head -n 1)"
    printf '%s' "$value"
}

usage_number_from_text() {
    local key="$1"
    local text="${2:-}"
    local value alt_key=""
    value="$(json_number_from_text "$key" "$text")"
    if [[ -z "$value" ]]; then
        value="$(printf '%s\n' "$text" | sed -n "s/^[[:space:]-]*${key}:[[:space:]]*\\([0-9][0-9.]*\\).*$/\\1/p" | head -n 1)"
    fi
    if [[ -z "$value" ]]; then
        case "$key" in
            input_tokens) alt_key="input" ;;
            output_tokens) alt_key="output" ;;
            total_tokens) alt_key="total" ;;
            estimated_cost_usd) alt_key="cost" ;;
        esac
        if [[ -n "$alt_key" ]]; then
            value="$(json_number_from_text "$alt_key" "$text")"
        fi
    fi
    printf '%s' "$value"
}

field_from_text() {
    local key="$1"
    local text="${2:-}"
    local value
    value="$(printf '%s\n' "$text" | sed -E -n "s/^[*[:space:]]*${key}:[*[:space:]]*(.*)$/\\1/p" | head -n 1 | sed -E 's/[[:space:]*]*$//')"
    printf '%s' "$value"
}

findings_count_from_text() {
    local text="${1:-}"
    local value
    value="$(json_number_from_text "findings_count" "$text")"
    if [[ -z "$value" ]]; then
        value="$(field_from_text "FINDINGS_COUNT" "$text" | sed -n 's/^\([0-9][0-9]*\).*$/\1/p' | head -n 1)"
    fi
    printf '%s' "${value:-null}"
}

read_only_enforcement_from_text() {
    local text="${1:-}"
    local value
    value="$(printf '%s\n' "$text" | sed -n 's/.*"read_only_enforcement"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
    if [[ -z "$value" ]]; then
        value="$(printf '%s\n' "$text" | sed -E -n 's/.*READ_ONLY_ENFORCEMENT:[*[:space:]]*(provider_enforced|contract_only|unavailable).*/\1/p' | head -n 1)"
    fi
    case "$value" in
        provider_enforced|contract_only|unavailable) printf '%s' "$value" ;;
        *) printf 'unavailable' ;;
    esac
}

template_path() {
    local name="$1"
    case "$name" in
        smoke|code-review|architecture-review|security-review)
            printf '%s/%s.md' "$TEMPLATES_DIR" "$name"
            ;;
        arch-review)
            printf '%s/architecture-review.md' "$TEMPLATES_DIR"
            ;;
        *)
            return 1
            ;;
    esac
}

contract_path() {
    local name="$1"
    printf '%s/contracts/%s.md' "$TEMPLATES_DIR" "$name"
}

append_section_file() {
    local title="$1"
    local file="$2"
    local out="$3"
    [[ -f "$file" ]] || { echo "required template file missing: $file" >&2; return 1; }
    {
        printf '\n## %s\n\n' "$title"
        cat "$file"
        printf '\n'
    } >> "$out"
}

parse_pr_ref() {
    local ref="$1"
    if [[ "$ref" =~ ^https://github.com/([^/]+/[^/]+)/pull/([0-9]+) ]]; then
        printf '%s %s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
        return 0
    fi
    if [[ "$ref" =~ ^([^[:space:]#/]+/[^[:space:]#/]+)#([0-9]+)$ ]]; then
        printf '%s %s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
        return 0
    fi
    return 1
}

render_pr_metadata() {
    local pr_ref="$1"
    local out="$2"
    command -v gh >/dev/null 2>&1 || { echo "BLOCKED: github_pr_metadata_unavailable (gh missing)" >&2; return 1; }
    command -v jq >/dev/null 2>&1 || { echo "BLOCKED: github_pr_metadata_unavailable (jq missing)" >&2; return 1; }

    local repo number view_json files checks diff_names
    if ! read -r repo number < <(parse_pr_ref "$pr_ref"); then
        echo "BLOCKED: github_pr_metadata_unavailable (unsupported PR ref: $pr_ref)" >&2
        return 1
    fi

    set +e
    view_json="$(gh pr view "$number" --repo "$repo" --json number,url,title,state,baseRefName,headRefName,baseRefOid,headRefOid,files,statusCheckRollup 2>&1)"
    local view_rc=$?
    diff_names="$(gh pr diff "$number" --repo "$repo" --name-only 2>&1)"
    local diff_rc=$?
    set -e
    if [[ "$view_rc" -ne 0 ]]; then
        echo "BLOCKED: github_pr_metadata_unavailable ($view_json)" >&2
        return 1
    fi
    if [[ "$diff_rc" -ne 0 ]]; then
        diff_names="unavailable: $diff_names"
    fi

    files="$(printf '%s\n' "$view_json" | jq -r '.files[]?.path // empty' | sed 's/^/- /')"
    checks="$(printf '%s\n' "$view_json" | jq -r '.statusCheckRollup[]? | "- " + (.name // "unknown") + ": " + (.status // "unknown") + "/" + (.conclusion // "pending")' 2>/dev/null || true)"

    {
        printf '\n## Pull Request Metadata\n\n'
        printf -- '- Repo: `%s`\n' "$repo"
        printf -- '- PR: #%s\n' "$(printf '%s\n' "$view_json" | jq -r '.number')"
        printf -- '- URL: %s\n' "$(printf '%s\n' "$view_json" | jq -r '.url')"
        printf -- '- Title: %s\n' "$(printf '%s\n' "$view_json" | jq -r '.title')"
        printf -- '- State: %s\n' "$(printf '%s\n' "$view_json" | jq -r '.state')"
        printf -- '- Base: %s `%s`\n' "$(printf '%s\n' "$view_json" | jq -r '.baseRefName')" "$(printf '%s\n' "$view_json" | jq -r '.baseRefOid')"
        printf -- '- Head: %s `%s`\n\n' "$(printf '%s\n' "$view_json" | jq -r '.headRefName')" "$(printf '%s\n' "$view_json" | jq -r '.headRefOid')"
        printf '### Changed Files\n\n'
        if [[ -n "$files" ]]; then printf '%s\n' "$files"; else printf -- '- unavailable\n'; fi
        printf '\n### Status Checks\n\n'
        if [[ -n "$checks" ]]; then printf '%s\n' "$checks"; else printf -- '- unavailable\n'; fi
        printf '\n### Diff Name-Only\n\n```text\n%s\n```\n' "$diff_names"
    } >> "$out"
}

build_review_prompt() {
    local out="$1"
    local template_name="$2"
    local pr_ref="$3"
    local prompt_text="$4"
    local prompt_file="$5"
    local read_only_shell="$6"

    : > "$out"
    printf '# dx-review prompt\n' >> "$out"

    if [[ -n "$template_name" || "$read_only_shell" == "true" ]]; then
        append_section_file "Read-Only Review Mode" "$(contract_path read-only-review-mode)" "$out"
    fi
    if [[ -n "$template_name" ]]; then
        append_section_file "Secret-Auth Invariant" "$(contract_path secret-auth-invariant)" "$out"
        append_section_file "Tool Routing" "$(contract_path tool-routing-review)" "$out"
    fi
    if [[ -n "$pr_ref" ]]; then
        render_pr_metadata "$pr_ref" "$out"
    fi
    if [[ -n "$template_name" ]]; then
        local tpath
        tpath="$(template_path "$template_name")" || { echo "unknown template: $template_name" >&2; return 1; }
        append_section_file "Review Template: $template_name" "$tpath" "$out"
        append_section_file "Reviewer Output Schema" "$(contract_path reviewer-output-schema)" "$out"
    fi
    if [[ -n "$prompt_file" ]]; then
        append_section_file "Additional Instructions" "$prompt_file" "$out"
    fi
    if [[ -n "$prompt_text" ]]; then
        {
            printf '\n## Additional Instructions\n\n'
            printf '%s\n' "$prompt_text"
        } >> "$out"
    fi
}

profile_for_reviewer() {
    case "$1" in
        *.claude) printf 'claude-code-review' ;;
        *.glm) printf 'cc-glm-review' ;;
        *.opencode) printf 'opencode-review' ;;
        *.gemini) printf 'gemini-burst' ;;
        *) printf 'unknown' ;;
    esac
}

provider_hint_for_reviewer() {
    case "$1" in
        *.claude) printf 'claude-code' ;;
        *.glm) printf 'cc-glm' ;;
        *.opencode) printf 'opencode' ;;
        *.gemini) printf 'gemini' ;;
        *) printf 'unknown' ;;
    esac
}

logical_lane_for_reviewer() {
    case "$1" in
        *.claude) printf 'claude' ;;
        *.glm|*.opencode) printf 'glm' ;;
        *.gemini) printf 'gemini' ;;
        *) printf '%s' "$1" ;;
    esac
}

reviewer_attempted() {
    local reviewer="$1"
    local provider="$2"
    local run_dir="$3"
    [[ -f "$run_dir/${reviewer}.start.log" ]] && return 0
    [[ -f "/tmp/dx-runner/${provider}/${reviewer}.log" ]] && return 0
    return 1
}

reviewer_is_failed() {
    local state="$1"
    local verdict="$2"
    case "$state" in
        start_failed|blocked|missing|exited_err|unknown|running)
            return 0
            ;;
    esac
    case "$verdict" in
        fail|failed|blocked|error)
            return 0
            ;;
    esac
    return 1
}

reviewer_is_completed() {
    local state="$1"
    case "$state" in
        exited_ok|no_op_success|stopped)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

summarize_reviews() {
    local beads="$1"
    local include_gemini="$2"
    local quiet="${3:-false}"
    local run_dir="/tmp/dx-review/${beads}"
    local summary_json="$run_dir/summary.json"
    local summary_md="$run_dir/summary.md"
    local -a profiles=("claude-code-review" "cc-glm-review")
    local -a reviewers=()
    local -a entries=()
    local -a md_rows=()
    local raw_total=0 raw_completed=0 raw_failed=0 raw_not_reached=0
    local total=0 completed=0 failed=0 quorum_not_reached=0
    local claude_completed=false claude_failed=false claude_not_reached=false
    local glm_completed=false glm_failed=false glm_not_reached=false
    local gemini_completed=false gemini_failed=false gemini_not_reached=false
    local profile reviewer

    mkdir -p "$run_dir"
    if [[ "$include_gemini" == "true" ]]; then
        profiles+=("gemini-burst")
    fi
    for profile in "${profiles[@]}"; do
        reviewers+=("$(reviewer_id_for_profile "$beads" "$profile")")
    done
    if reviewer_attempted "$(reviewer_id_for_profile "$beads" "opencode-review")" "opencode" "$run_dir"; then
        reviewers+=("$(reviewer_id_for_profile "$beads" "opencode-review")")
    fi

    for reviewer in "${reviewers[@]}"; do
        raw_total=$((raw_total + 1))
        local reviewer_profile state reason provider display_state verdict
        local check_json check_rc report_json report_rc report_path log_path start_log
        local start_log_text start_reason
        local input_tokens output_tokens total_tokens estimated_cost usage_available usage_source
        local findings_count read_only_enforcement log_text normalized_log_text parse_text
        local usage_json verdict_json
        local reviewer_failed=false reviewer_completed=false
        local lane

        reviewer_profile="$(profile_for_reviewer "$reviewer")"
        start_log="$run_dir/${reviewer}.start.log"
        report_path="$run_dir/${reviewer}.report.json"
        start_log_text=""
        if [[ -f "$start_log" ]]; then
            start_log_text="$(cat "$start_log" 2>/dev/null || true)"
        fi

        set +e
        check_json="$("$DX_RUNNER" check --beads "$reviewer" --json 2>&1)"
        check_rc=$?
        set -e

        state="$(printf '%s\n' "$check_json" | state_from_check_json)"
        reason="$(printf '%s\n' "$check_json" | reason_from_json)"
        provider="$(printf '%s\n' "$check_json" | provider_from_json)"

        set +e
        report_json="$("$DX_RUNNER" report --beads "$reviewer" --format json 2>&1)"
        report_rc=$?
        set -e
        printf '%s\n' "$report_json" > "$report_path"

        if [[ -z "$state" ]]; then
            state="$(printf '%s\n' "$report_json" | state_from_check_json)"
        fi
        if [[ -z "$reason" ]]; then
            reason="$(printf '%s\n' "$report_json" | reason_from_json)"
        fi
        start_reason="$(reason_from_start_log "$start_log_text")"
        if [[ (-z "$state" || "$state" == "missing" || "$state" == "unknown") && -n "$start_log_text" && "$check_rc" -ne 0 && "$report_rc" -ne 0 ]]; then
            state="start_failed"
        fi
        if [[ (-z "$reason" || "$reason" == "no_meta" || "$reason" == "unknown") && -n "$start_reason" ]]; then
            reason="$start_reason"
        fi
        if [[ -z "$provider" ]]; then
            provider="$(printf '%s\n' "$report_json" | provider_from_json)"
        fi

        state="${state:-unknown}"
        reason="${reason:-unknown}"
        provider="${provider:-$(provider_hint_for_reviewer "$reviewer")}"
        display_state="$(review_state_for_display "$state")"

        log_path="/tmp/dx-runner/${provider}/${reviewer}.log"
        log_text=""
        if [[ -f "$log_path" ]]; then
            log_text="$(cat "$log_path" 2>/dev/null || true)"
        else
            log_path=""
        fi
        normalized_log_text="$(printf '%s' "$log_text" | sed 's/\\n/\
/g')"
        parse_text="${report_json}"$'\n'"${check_json}"$'\n'"${normalized_log_text}"
        verdict="$(verdict_from_text "$parse_text")"
        findings_count="$(findings_count_from_text "$parse_text")"
        read_only_enforcement="$(read_only_enforcement_from_text "$parse_text")"

        input_tokens="$(usage_number_from_text "input_tokens" "$parse_text")"
        output_tokens="$(usage_number_from_text "output_tokens" "$parse_text")"
        total_tokens="$(usage_number_from_text "total_tokens" "$parse_text")"
        estimated_cost="$(usage_number_from_text "estimated_cost_usd" "$parse_text")"
        usage_available=false
        usage_source=""
        if [[ -n "$input_tokens" || -n "$output_tokens" || -n "$total_tokens" || -n "$estimated_cost" ]]; then
            usage_available=true
            usage_source="dx-runner-report-or-log"
        fi

        if [[ -z "$input_tokens" ]]; then input_tokens="null"; fi
        if [[ -z "$output_tokens" ]]; then output_tokens="null"; fi
        if [[ -z "$total_tokens" ]]; then total_tokens="null"; fi
        if [[ -z "$estimated_cost" ]]; then estimated_cost="null"; fi
        if [[ -n "$usage_source" ]]; then
            usage_source="\"$(json_escape "$usage_source")\""
        else
            usage_source="null"
        fi

        usage_json=$(cat <<EOF
{"available":${usage_available},"input_tokens":${input_tokens},"output_tokens":${output_tokens},"total_tokens":${total_tokens},"estimated_cost_usd":${estimated_cost},"source":${usage_source}}
EOF
)

        if [[ ! -f "$start_log" ]]; then
            start_log=""
        fi

        if [[ -n "$verdict" ]]; then
            verdict_json="\"$(json_escape "$verdict")\""
        else
            verdict_json="null"
        fi

        if reviewer_is_failed "$state" "$verdict"; then
            reviewer_failed=true
            raw_failed=$((raw_failed + 1))
        fi
        if reviewer_is_completed "$state" && [[ "$reviewer_failed" != "true" ]]; then
            reviewer_completed=true
            raw_completed=$((raw_completed + 1))
        fi
        if [[ "$state" == "missing" || "$state" == "start_failed" || "$state" == "running" || "$state" == "unknown" ]]; then
            raw_not_reached=$((raw_not_reached + 1))
        fi

        lane="$(logical_lane_for_reviewer "$reviewer")"
        case "$lane" in
            claude)
                [[ "$reviewer_completed" == "true" ]] && claude_completed=true
                [[ "$reviewer_failed" == "true" ]] && claude_failed=true
                [[ "$state" == "missing" || "$state" == "start_failed" || "$state" == "running" || "$state" == "unknown" ]] && claude_not_reached=true
                ;;
            glm)
                [[ "$reviewer_completed" == "true" ]] && glm_completed=true
                [[ "$reviewer_failed" == "true" ]] && glm_failed=true
                [[ "$state" == "missing" || "$state" == "start_failed" || "$state" == "running" || "$state" == "unknown" ]] && glm_not_reached=true
                ;;
            gemini)
                [[ "$reviewer_completed" == "true" ]] && gemini_completed=true
                [[ "$reviewer_failed" == "true" ]] && gemini_failed=true
                [[ "$state" == "missing" || "$state" == "start_failed" || "$state" == "running" || "$state" == "unknown" ]] && gemini_not_reached=true
                ;;
        esac

        entries+=("$(cat <<EOF
{"reviewer":"$(json_escape "$reviewer")","profile":"$(json_escape "$reviewer_profile")","state":"$(json_escape "$display_state")","reason_code":"$(json_escape "$reason")","verdict":${verdict_json},"findings_count":${findings_count},"read_only_enforcement":"$(json_escape "$read_only_enforcement")","report_path":"$(json_escape "$report_path")","log_path":"$(json_escape "$log_path")","start_log":"$(json_escape "$start_log")","usage":${usage_json}}
EOF
)")
        md_rows+=("| ${reviewer} | ${reviewer_profile} | ${display_state} | ${reason} | ${verdict:-n/a} | ${findings_count} | ${read_only_enforcement} | available=${usage_available} |")
    done

    local i exit_code
    local reviewers_json=""
    for i in "${!entries[@]}"; do
        if [[ "$i" -gt 0 ]]; then
            reviewers_json+=","
        fi
        reviewers_json+="${entries[$i]}"
    done

    total=2
    [[ "$include_gemini" == "true" ]] && total=3

    if [[ "$claude_completed" == "true" ]]; then completed=$((completed + 1)); elif [[ "$claude_not_reached" == "true" ]]; then quorum_not_reached=$((quorum_not_reached + 1)); else failed=$((failed + 1)); fi
    if [[ "$glm_completed" == "true" ]]; then completed=$((completed + 1)); elif [[ "$glm_not_reached" == "true" ]]; then quorum_not_reached=$((quorum_not_reached + 1)); else failed=$((failed + 1)); fi
    if [[ "$include_gemini" == "true" ]]; then
        if [[ "$gemini_completed" == "true" ]]; then completed=$((completed + 1)); elif [[ "$gemini_not_reached" == "true" ]]; then quorum_not_reached=$((quorum_not_reached + 1)); else failed=$((failed + 1)); fi
    fi

    if [[ "$quorum_not_reached" -gt 0 ]]; then
        exit_code=2
    elif [[ "$failed" -gt 0 ]]; then
        exit_code=1
    else
        exit_code=0
    fi

    cat > "$summary_json" <<EOF
{"beads":"$(json_escape "$beads")","run_dir":"$(json_escape "$run_dir")","summary_md":"$(json_escape "$summary_md")","summary_json":"$(json_escape "$summary_json")","quorum":{"total":${total},"completed":${completed},"failed":${failed},"not_reached":${quorum_not_reached},"exit_code":${exit_code}},"provider_outcomes":{"total":${raw_total},"completed":${raw_completed},"failed":${raw_failed},"not_reached":${raw_not_reached}},"reviewers":[${reviewers_json}]}
EOF

    {
        printf '# dx-review summary: %s\n\n' "$beads"
        printf 'effective quorum: %s/%s completed, %s failed\n' "$completed" "$total" "$failed"
        printf 'provider outcomes: %s completed, %s failed, %s not reached\n\n' "$raw_completed" "$raw_failed" "$raw_not_reached"
        printf '| reviewer | profile | state | reason | verdict | findings | read-only | usage |\n'
        printf '|---|---|---|---|---|---|---|---|\n'
        local row
        for row in "${md_rows[@]}"; do
            printf '%s\n' "$row"
        done
        printf '\n- summary.json: `%s`\n' "$summary_json"
        printf -- '- summary.md: `%s`\n' "$summary_md"
    } > "$summary_md"

    if [[ "$quiet" != "true" ]]; then
        echo "effective quorum: ${completed}/${total} completed, ${failed} failed"
        echo "provider outcomes: ${raw_completed} completed, ${raw_failed} failed, ${raw_not_reached} not reached"
        echo "summary.json: $summary_json"
        echo "summary.md: $summary_md"
    fi

    return "$exit_code"
}

run_doctor_for_profiles() {
    local worktree="$1"
    local include_gemini="$2"
    local failures=0 profile rc
    local -a profiles=("claude-code-review" "cc-glm-review")

    [[ -n "$worktree" && -d "$worktree" ]] || { echo "doctor requires existing --worktree" >&2; return 2; }
    if [[ "$include_gemini" == "true" ]]; then
        profiles+=("gemini-burst")
    fi

    for profile in "${profiles[@]}"; do
        [[ -n "$profile" ]] || continue
        echo "doctor profile=$profile"
        set +e
        DX_RUNNER_PREFLIGHT_WORKTREE="$worktree" "$DX_RUNNER" preflight --profile "$profile" --worktree "$worktree"
        rc=$?
        set -e
        if [[ "$rc" -ne 0 ]]; then
            failures=$((failures + 1))
        fi
    done

    [[ "$failures" -eq 0 ]]
}

doctor_cmd() {
    local worktree="" include_gemini=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --worktree)
                worktree="${2:-}"
                shift 2
                ;;
            --gemini)
                include_gemini=true
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "unknown arg: $1" >&2
                usage >&2
                exit 2
                ;;
        esac
    done
    run_doctor_for_profiles "$worktree" "$include_gemini"
}

summarize_cmd() {
    local beads="" include_gemini=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --beads)
                beads="${2:-}"
                shift 2
                ;;
            --gemini)
                include_gemini=true
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "unknown arg: $1" >&2
                usage >&2
                exit 2
                ;;
        esac
    done

    [[ -n "$beads" ]] || { echo "summarize requires --beads" >&2; exit 2; }
    valid_beads_id "$beads" || { echo "invalid Beads id: $beads" >&2; exit 2; }
    summarize_reviews "$beads" "$include_gemini" "false"
}

run_cmd() {
    local beads="" worktree="" prompt="" prompt_file="" include_gemini=false wait=false timeout_sec=300 poll_sec=5
    local pr_ref="" template_name="" read_only_shell=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --beads)
                beads="${2:-}"
                shift 2
                ;;
            --worktree)
                worktree="${2:-}"
                shift 2
                ;;
            --prompt)
                prompt="${2:-}"
                shift 2
                ;;
            --prompt-file)
                prompt_file="${2:-}"
                shift 2
                ;;
            --pr|--github-pr)
                pr_ref="${2:-}"
                shift 2
                ;;
            --template)
                template_name="${2:-}"
                shift 2
                ;;
            --read-only-shell)
                read_only_shell=true
                shift
                ;;
            --gemini)
                include_gemini=true
                shift
                ;;
            --wait)
                wait=true
                shift
                ;;
            --timeout-sec)
                timeout_sec="${2:-300}"
                shift 2
                ;;
            --poll-sec)
                poll_sec="${2:-5}"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "unknown arg: $1" >&2
                usage >&2
                exit 2
                ;;
        esac
    done

    [[ -n "$beads" ]] || { echo "run requires --beads" >&2; exit 2; }
    valid_beads_id "$beads" || { echo "invalid Beads id: $beads" >&2; exit 2; }
    [[ -n "$worktree" && -d "$worktree" ]] || { echo "run requires existing --worktree" >&2; exit 2; }
    if [[ -n "$prompt" && -n "$prompt_file" ]]; then
        echo "use --prompt or --prompt-file, not both" >&2
        exit 2
    fi
    if [[ -z "$prompt" && -z "$prompt_file" && -z "$template_name" && -z "$pr_ref" ]]; then
        echo "run requires --prompt, --prompt-file, --template, or --pr" >&2
        exit 2
    fi
    [[ -x "$DX_RUNNER" ]] || { echo "dx-runner not executable: $DX_RUNNER" >&2; exit 2; }

    local run_dir="/tmp/dx-review/${beads}"
    mkdir -p "$run_dir"
    if [[ -n "$template_name" || -n "$pr_ref" || "$read_only_shell" == "true" ]]; then
        local addendum_file="$prompt_file"
        prompt_file="$run_dir/review.prompt"
        build_review_prompt "$prompt_file" "$template_name" "$pr_ref" "$prompt" "$addendum_file" "$read_only_shell"
    elif [[ -n "$prompt" ]]; then
        prompt_file="$run_dir/review.prompt"
        printf '%s\n' "$prompt" > "$prompt_file"
    fi
    [[ -f "$prompt_file" ]] || { echo "prompt file not found: $prompt_file" >&2; exit 2; }

    local -a profiles=("cc-glm-review" "claude-code-review")
    if [[ "$include_gemini" == "true" ]]; then
        profiles+=("gemini-burst")
    fi

    local -a reviewers=()
    local -a start_pids=()
    local -a start_logs=()
    local -a start_rcs=()
    local -a start_failed=()
    local -a final_states=()
    local failures=0
    local profile reviewer start_log

    echo "dx-review reviewers: ${profiles[*]}"
    for profile in "${profiles[@]}"; do
        reviewer="$(reviewer_id_for_profile "$beads" "$profile")"
        reviewers+=("$reviewer")
        start_log="$run_dir/${reviewer}.start.log"
        start_logs+=("$start_log")
        echo "launching reviewer=$reviewer profile=$profile start_log=$start_log"
        "$DX_RUNNER" start --profile "$profile" --beads "$reviewer" --prompt-file "$prompt_file" --worktree "$worktree" >"$start_log" 2>&1 &
        start_pids+=("$!")
    done

    local i start_rc
    for i in "${!start_pids[@]}"; do
        reviewer="${reviewers[$i]}"
        profile="${profiles[$i]}"
        start_log="${start_logs[$i]}"
        set +e
        wait "${start_pids[$i]}"
        start_rc=$?
        set -e
        start_rcs[$i]="$start_rc"
        echo "start result reviewer=$reviewer profile=$profile rc=$start_rc"
        sed -n '1,220p' "$start_log"
        if [[ "$start_rc" -ne 0 ]]; then
            echo "reviewer_start_failed reviewer=$reviewer profile=$profile rc=$start_rc start_log=$start_log" >&2
            start_failed[$i]=true
            final_states[$i]=start_failed
            failures=$((failures + 1))
        else
            start_failed[$i]=false
            final_states[$i]=running
        fi
    done

    local fallback_profile fallback_reviewer fallback_start_log fallback_start_rc
    for i in "${!profiles[@]}"; do
        if [[ "${profiles[$i]}" == "cc-glm-review" && "${start_failed[$i]:-false}" == "true" ]]; then
            fallback_profile="opencode-review"
            fallback_reviewer="$(reviewer_id_for_profile "$beads" "$fallback_profile")"
            fallback_start_log="$run_dir/${fallback_reviewer}.start.log"
            echo "glm_primary_start_failed reviewer=${reviewers[$i]} profile=cc-glm-review; launching fallback reviewer=$fallback_reviewer profile=$fallback_profile start_log=$fallback_start_log" >&2
            profiles+=("$fallback_profile")
            reviewers+=("$fallback_reviewer")
            start_logs+=("$fallback_start_log")
            "$DX_RUNNER" start --profile "$fallback_profile" --beads "$fallback_reviewer" --prompt-file "$prompt_file" --worktree "$worktree" >"$fallback_start_log" 2>&1 &
            local fallback_pid="$!"
            set +e
            wait "$fallback_pid"
            fallback_start_rc=$?
            set -e
            start_rcs+=("$fallback_start_rc")
            echo "start result reviewer=$fallback_reviewer profile=$fallback_profile rc=$fallback_start_rc"
            sed -n '1,220p' "$fallback_start_log"
            if [[ "$fallback_start_rc" -ne 0 ]]; then
                echo "reviewer_start_failed reviewer=$fallback_reviewer profile=$fallback_profile rc=$fallback_start_rc start_log=$fallback_start_log" >&2
                start_failed+=(true)
                final_states+=(start_failed)
                failures=$((failures + 1))
            else
                start_failed+=(false)
                final_states+=(running)
                if [[ "$failures" -gt 0 ]]; then
                    failures=$((failures - 1))
                fi
            fi
        fi
    done

    if [[ "$wait" != "true" ]]; then
        [[ "$failures" -eq 0 ]] || exit 1
        return 0
    fi

    local deadline now all_done check_json state display_state
    local timed_out=false
    deadline=$(($(date +%s) + timeout_sec))
    while true; do
        all_done=true
        for i in "${!reviewers[@]}"; do
            reviewer="${reviewers[$i]}"
            if [[ "${start_failed[$i]:-false}" == "true" ]]; then
                echo "reviewer=$reviewer state=start_failed rc=${start_rcs[$i]:-1}"
                continue
            fi
            set +e
            check_json="$("$DX_RUNNER" check --beads "$reviewer" --json 2>&1)"
            local check_rc=$?
            set -e
            state="$(printf '%s\n' "$check_json" | state_from_check_json)"
            state="${state:-unknown}"
            display_state="$(review_state_for_display "$state")"
            final_states[$i]="$display_state"
            echo "reviewer=$reviewer state=$display_state raw_state=$state rc=$check_rc"
            if ! is_terminal_state "$state"; then
                all_done=false
            fi
        done

        if [[ "$all_done" == "true" ]]; then
            break
        fi
        now="$(date +%s)"
        if [[ "$now" -ge "$deadline" ]]; then
            echo "dx-review timed out after ${timeout_sec}s" >&2
            failures=$((failures + 1))
            timed_out=true
            break
        fi
        sleep "$poll_sec"
    done

    echo "dx-review reports:"
    for i in "${!reviewers[@]}"; do
        reviewer="${reviewers[$i]}"
        echo "--- $reviewer ---"
        if [[ "${start_failed[$i]:-false}" == "true" ]]; then
            printf '{"beads":"%s","provider_profile":"%s","state":"start_failed","reason_code":"dx_runner_start_failed","start_exit_code":%s,"start_log":"%s"}\n' \
                "$(json_escape "$reviewer")" "$(json_escape "${profiles[$i]}")" "${start_rcs[$i]:-1}" "$(json_escape "${start_logs[$i]}")"
            continue
        fi
        local report_json report_rc report_state
        set +e
        report_json="$("$DX_RUNNER" report --beads "$reviewer" --format json 2>&1)"
        report_rc=$?
        set -e
        printf '%s\n' "$report_json"
        report_state="$(printf '%s\n' "$report_json" | state_from_check_json)"
        if [[ "$report_rc" -ne 0 || "$report_state" == "exited_err" || "$report_state" == "blocked" || "$report_state" == "missing" ]]; then
            failures=$((failures + 1))
        fi
    done

    local summarize_rc
    set +e
    summarize_reviews "$beads" "$include_gemini" "false"
    summarize_rc=$?
    set -e
    if [[ "$summarize_rc" -ne 0 ]]; then
        failures=$((failures + 1))
    fi

    if [[ "$timed_out" == "true" ]]; then
        exit 124
    fi
    [[ "$failures" -eq 0 ]] || exit 1
}

main() {
    require_bash
    local cmd="${1:-}"
    shift || true
    case "$cmd" in
        doctor) doctor_cmd "$@" ;;
        run) run_cmd "$@" ;;
        summarize) summarize_cmd "$@" ;;
        -h|--help|"") usage ;;
        *)
            echo "unknown command: $cmd" >&2
            usage >&2
            exit 2
            ;;
    esac
}

main "$@"
