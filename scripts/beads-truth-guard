#!/usr/bin/env bash
set -euo pipefail

BEADS_ROOT="${BEADS_DIR:-$HOME/.beads-runtime/.beads}"
METADATA="$BEADS_ROOT/metadata.json"

if [ ! -f "$METADATA" ]; then
  echo "beads-truth-guard: metadata not found at $METADATA"
  echo "Cannot verify backend mode. Use live CLI queries for truth:" 
  echo "  bdx show <id> --json"
  echo "  bdx list --json"
  echo "  beads-dolt status --json"
  exit 2
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "beads-truth-guard: jq is required to inspect $METADATA"
  echo "Cannot verify backend mode safely. Use live CLI queries for truth:"
  echo "  bdx show <id> --json"
  echo "  bdx list --json"
  echo "  beads-dolt status --json"
  exit 2
fi

DB_TYPE="$(jq -r '.database // empty' "$METADATA" 2>/dev/null || true)"

if [ -z "$DB_TYPE" ]; then
  echo "beads-truth-guard: unable to determine backend type from $METADATA"
  echo "Cannot verify backend mode safely. Use live CLI queries for truth:"
  echo "  bdx show <id> --json"
  echo "  bdx list --json"
  echo "  beads-dolt status --json"
  exit 2
fi

if [ "$DB_TYPE" = "dolt" ]; then
  cat <<'MSG'
beads-truth-guard: DOLT MODE DETECTED

Do not use file-based truth checks in this mode:
  ~/.beads-runtime/.beads/issues.jsonl
  ~/.beads-runtime/.beads/backup/issues.jsonl

In dolt-native mode, JSONL exports are not the live source of truth.
Use live commands instead:
  bdx show <id> --json
  bdx list --json
  beads-dolt status --json
MSG
  exit 3
fi

echo "beads-truth-guard: backend is '$DB_TYPE' (non-dolt)."
echo "Live CLI truth checks are still recommended: bdx show/list --json"
exit 0
