#!/usr/bin/env python3
"""Guard repo-memory refresh diffs so scheduled agents can only change docs."""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from fnmatch import fnmatchcase
from pathlib import Path


DEFAULT_ALLOWED = (
    "docs/architecture/**",
    "AGENTS.md",
    "AGENTS.local.md",
)

FORBIDDEN_HINTS = (
    ".env",
    ".secret",
    "package-lock.json",
    "pnpm-lock.yaml",
    "poetry.lock",
    "yarn.lock",
    "requirements.txt",
)


def _run_git(repo: Path, args: list[str]) -> tuple[int, str, str]:
    try:
        out = subprocess.run(
            ["git", *args],
            cwd=str(repo),
            text=True,
            capture_output=True,
            check=False,
        )
        return out.returncode, out.stdout.strip(), out.stderr.strip()
    except (FileNotFoundError, OSError) as exc:
        return 1, "", str(exc)


def _normalize(path: str) -> str:
    value = path.replace("\\", "/")
    while value.startswith("./"):
        value = value[2:]
    return value


def _changed_files(repo: Path, base_ref: str | None) -> tuple[list[str], str | None]:
    diff_target = f"{base_ref}...HEAD" if base_ref else "HEAD"
    args = ["diff", "--name-only"]
    if base_ref:
        args.append(diff_target)
    rc, out, err = _run_git(repo, args)
    if rc != 0:
        return [], err or "git diff failed"
    return sorted({_normalize(line) for line in out.splitlines() if line.strip()}), None


def main() -> int:
    parser = argparse.ArgumentParser(description="Guard repo-memory refresh diffs.")
    parser.add_argument("--repo", required=True, help="Path to repository root")
    parser.add_argument("--base-ref", help="Base ref to diff against")
    parser.add_argument("--json", action="store_true", dest="json_output", help="Emit JSON output")
    parser.add_argument("--allowed", action="append", default=[], help="Allowed glob pattern (repeatable)")
    args = parser.parse_args()

    repo = Path(args.repo).resolve()
    if not repo.exists() or not repo.is_dir():
        print(f"ERROR: repo path does not exist: {repo}", file=sys.stderr)
        return 2

    allowed = tuple(args.allowed) if args.allowed else DEFAULT_ALLOWED
    changed, diff_error = _changed_files(repo, args.base_ref)
    forbidden: list[dict[str, str]] = []

    if diff_error:
        forbidden.append({"path": "<git-diff>", "reason": diff_error})

    for path in changed:
        allowed_match = any(fnmatchcase(path, pattern) for pattern in allowed)
        forbidden_hint = any(hint in path for hint in FORBIDDEN_HINTS)
        if not allowed_match:
            forbidden.append({"path": path, "reason": "path is outside allowed repo-memory refresh surface"})
        elif forbidden_hint:
            forbidden.append({"path": path, "reason": "path looks like secret/dependency/runtime config"})

    status = "pass" if not forbidden else "fail"
    payload = {
        "status": status,
        "repo": str(repo),
        "base_ref": args.base_ref,
        "allowed_patterns": list(allowed),
        "changed_files": changed,
        "forbidden": forbidden,
        "summary": {"changed_files": len(changed), "forbidden": len(forbidden)},
    }

    if args.json_output:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"dx-repo-memory-guard: {status.upper()} (changed={len(changed)}, forbidden={len(forbidden)})")
        for item in forbidden:
            print(f"  - forbidden: {item['path']}: {item['reason']}")

    return 0 if status == "pass" else 1


if __name__ == "__main__":
    sys.exit(main())
